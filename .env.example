# ──── Auth0 Configuration ────
AUTH0_DOMAIN=         # e.g. your-tenant.us.auth0.com
AUTH0_CLIENT_ID=      # From Auth0 Dashboard > Applications
AUTH0_CLIENT_SECRET=  # From Auth0 Dashboard > Applications
AUTH0_SECRET=         # Generate: openssl rand -hex 32
APP_BASE_URL=http://localhost:3000

# ──── Database (DigitalOcean Managed Postgres) ────
# Add ?sslmode=require at the end
DATABASE_URL=postgresql://user:pass@host:25060/defaultdb?sslmode=require

# ──── Auth0 Dashboard Setup ────
# 1. Create a "Regular Web Application" in Auth0
# 2. Add http://localhost:3000/auth/callback to Allowed Callback URLs  
# 3. Add http://localhost:3000 to Allowed Logout URLs
# 4. Under Authentication > Social, create a GitHub connection:
#    - Use your GitHub OAuth App credentials
#    - Enable scopes: repo, read:user, user:email
#    - Toggle ON "Connected Accounts for Token Vault" under Purpose
# 5. Under your Application settings, enable the Token Exchange grant type
