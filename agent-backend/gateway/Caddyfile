# ── Caddy Gateway for Lightly Preview ──
# Serves HTTPS for *.preview.lightly.ink subdomains
# Caddy auto-obtains TLS certificates on-demand via Let's Encrypt
#
# How it works:
#   1. Request comes in for {droplet_id}.preview.lightly.ink
#   2. Caddy asks the sidecar: "should I issue a cert for this domain?"
#   3. If yes, Caddy obtains a cert (cached for future use)
#   4. Caddy extracts the droplet ID from the subdomain
#   5. Rewrites the request to /proxy/{droplet_id}/{path}
#   6. Reverse proxies to the sidecar on localhost:8080
#   7. Sidecar looks up the droplet IP and proxies to http://{ip}:3000

{
    on_demand_tls {
        ask http://localhost:8080/check
    }
}

*.preview.lightly.ink {
    tls {
        on_demand
    }

    # Extract the droplet ID from the subdomain
    # e.g. "12345678" from "12345678.preview.lightly.ink"
    @subdomain header_regexp sub Host ^([^.]+)\.preview\.lightly\.ink$

    handle @subdomain {
        # Rewrite to sidecar's proxy endpoint
        rewrite * /proxy/{re.sub.1}{uri}

        reverse_proxy localhost:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Reject requests that don't match a subdomain pattern
    handle {
        respond "Not found" 404
    }
}
